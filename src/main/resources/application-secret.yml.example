# 大模型 API 密钥配置（默认千问，可自行更换为其他模型）
# 使用方式：复制本文件为 application-secret.yml，并填入真实 api-key（application-secret.yml 已加入 .gitignore，不会提交）
# 若使用其他模型（如 OpenAI、Azure、智谱等），请在 application.yml 中切换 spring.ai 下对应 provider 的配置，并在此填写该 provider 的 api-key。
#
# spring:
#   ai:
#     dashscope:
#       api-key: sk-xxxxxxxxxxxxxxxx

spring:
  ai:
    dashscope:
      api-key: your-dashscope-api-key-here
